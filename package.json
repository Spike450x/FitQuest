{
  "name": "fitness-rpg",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:ci": "dotenv -e .env.ci -- next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run --config vitest.rules.config.ts",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "validate:indexes": "node scripts/validate-firestore-indexes.mjs",
    "deploy:prod": "node scripts/validate-firestore-indexes.mjs && npx firebase deploy --only firestore:indexes,firestore:rules && npx firebase deploy --only functions --force"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "^15.5.18",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "eslint-config-prettier": "^10.1.8",
    "firebase-tools": "^13.35.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "tar": "^7.5.11",
    "glob": "^10.5.0",
    "@tootallnate/once": "^3.0.1",
    "postcss": "^8.5.10"
  }
}
