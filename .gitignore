# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log
firebase-debug.*.log

# local env files — never commit these
.env*.local

# Firebase admin / service-account credentials — never commit these
serviceAccount*.json
*-firebase-adminsdk-*.json
*-service-account-*.json

# Claude Code — machine-specific settings (permissions, hooks, hardcoded paths)
.claude/settings.local.json

# Claude Code — IDE launch config (machine-specific dev server settings)
.claude/launch.json

# Claude Code — git worktrees managed by Claude (parallel branch checkouts)
.claude/worktrees/

# superpowers brainstorm sessions (local mockup files)
.superpowers/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase Cloud Functions — compiled output (built by predeploy hook)
functions/lib/

# Playwright auth state (contains real tokens from emulator — never commit)
tests/e2e/.auth/user.json
